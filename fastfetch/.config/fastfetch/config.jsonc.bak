{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "display": {
        "separator": "  "
    },
    "modules": [
        {
            "type": "custom", // HardwareStart
            // {#1} is equivalent to `\u001b[1m`. {#} is equivalent to `\u001b[m`
            "format": "╭─────────── {#1;31}Hardware Information{#} ───────────┐"
        },
        {
            "type": "cpu",
            "key": "{#}│ {#1;36} {#1;35}CPU"
        },
        {
            "type": "gpu",
            "key": "{#}│ {#1;36}󰢮 {#1;37}GPU"
        },
        {
            "type": "memory",
            "key": "{#}│ {#1;36} {#1;34}RAM"
        },
	{
            "type": "swap",
            "key": "{#}│ {#1;36}󰾴 {#1;35}Swap"
        },
        {
            "type": "custom", // SoftwareStart
            "format": "├─────────── {#1;31}Software Information{#} ───────────┤"
        },
        {
            "type": "os",
            "key": "{#}│ {#1;36} {#1;34}System"
        },
        {
            "type": "kernel",
            "key": "{#}│ {#1;36} {#1;35}Kernel",
            "format": "{1} {2}"
        },
        {
            "type": "terminal",
            "key": "{#}│ {#1;36} {#1;37}Terminal"
        },
        {
            "type": "packages",
            "key": "{#}│ {#1;36} {#1;34}Packages"
        },
	{
            "type": "uptime",
            "key": "{#}│ {#1;36} {#1;35}Uptime"
        },
        {
            "type": "custom", // SoftwareStart
            "format": "├─────────── {#1;31}Theme Details{#} ───────────┤"
        },
        {
            "type": "theme",
            "key": "{#}│ {#1;36} {#1;34}Desktop Theme"
        },
        {
            "type": "icons",
            "key": "{#}│ {#1;36} {#1;35}Icon Theme"
        },
	{
            "type": "font",
            "key": "{#}│ {#1;36} {#1;34}Font"
        },
        {
            "type": "shell",
            "key": "{#}│ {#1;36} {#1;37}Current Shell"
        },
        {
            "type": "custom", // InformationEnd
            "format": "╰────────────────────────────────────────────┘"
        },
        {
            "type": "custom", // Colours
            "format": " {#1;30} {#1;31} {#1;32} {#1;33} {#1;34} {#1;35} {#1;36} {#1;37}"
        },
    ]
}
